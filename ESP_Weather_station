        document.getElementById('p_v').innerHTML = d.p.toFixed(1) + ' <span style="font-size:22px; font-weight:600; color:var(--text-muted)">mmHg</span>'; 
        document.getElementById('r_v').innerHTML = d.r + ' <span style="font-size:22px; font-weight:600; color:var(--text-muted)"></span>'; 
        
        renderStatuses(d);

        document.getElementById('min_t').innerText = d.mt.toFixed(1) + ' °C'; document.getElementById('avg_t').innerText = d.at.toFixed(1) + ' °C'; document.getElementById('max_t').innerText = d.xt.toFixed(1) + ' °C';
        document.getElementById('min_h').innerText = d.mh.toFixed(1) + ' %'; document.getElementById('avg_h').innerText = d.ah.toFixed(1) + ' %'; document.getElementById('max_h').innerText = d.xh.toFixed(1) + ' %';
        document.getElementById('min_p').innerText = d.mp.toFixed(1) + ' mmHg'; document.getElementById('avg_p').innerText = d.ap.toFixed(1) + ' mmHg'; document.getElementById('max_p').innerText = d.xp.toFixed(1) + ' mmHg';
        
        document.getElementById('min_r').innerText = d.mr;
        document.getElementById('avg_r').innerText = d.ar.toFixed(1);
        document.getElementById('max_r').innerText = d.xr;

        if(liveData.t.length >= maxPoints) { 
