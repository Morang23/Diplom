        if(histDataCache.t.length > 0) {
            draw('hist_t', histDataCache.t, null, '#ff3b30', '°C', 24, 't');
            draw('hist_h', histDataCache.h, null, '#007aff', '%', 24, 'h');
            draw('hist_p', histDataCache.p, null, '#af52de', ' mmHg', 24, 'p');
            draw('hist_r', histDataCache.r, null, '#5ac8fa', '', 24, 'r');
        }
    }

    setInterval(() => {
      fetch('/history').then(r => r.json()).then(d => {
        histDataCache = d;
        drawAllHistory();
      });
    }, 15000);
  </script>
</body>
</html>
)rawliteral";

// --- СЕРВЕРНІ ФУНКЦІЇ ---

void handleRoot() { server.send(200, "text/html", index_html); }

void handleData() {
  float t = bme.readTemperature();
  float h = bme.readHumidity();
  float p = bme.readPressure() / 133.32F;
  int r = getRain();
  
  float avgT = (countReads > 0) ? (sumT / countReads) : 0;
  float avgH = (countReads > 0) ? (sumH / countReads) : 0;
  float avgP = (countReads > 0) ? (sumP / countReads) : 0;
  float avgR = (countReads > 0) ? (sumR / countReads) : 0;

  char json[512];
  snprintf(json, sizeof(json), 
    "{\"t\":%.1f, \"h\":%.1f, \"p\":%.1f, \"r\":%d, \"mt\":%.1f, \"xt\":%.1f, \"at\":%.1f, \"mh\":%.1f, \"xh\":%.1f, \"ah\":%.1f, \"mp\":%.1f, \"xp\":%.1f, \"ap\":%.1f, \"mr\":%d, \"xr\":%d, \"ar\":%.1f}", 
    t, h, p, r, minT, maxT, avgT, minH, maxH, avgH, minP, maxP, avgP, minR, maxR, avgR);
  server.send(200, "application/json", json);
}

void handleHistory() {
  char buff[1024]; 
  int pos = snprintf(buff, sizeof(buff), "{\"t\":[");
  for(int i=0; i<24; i++) pos += snprintf(buff+pos, sizeof(buff)-pos, "%.1f%s", histT[i], i<23?",":"");
  
  pos += snprintf(buff+pos, sizeof(buff)-pos, "],\"h\":[");
  for(int i=0; i<24; i++) pos += snprintf(buff+pos, sizeof(buff)-pos, "%.1f%s", histH[i], i<23?",":"");
  
  pos += snprintf(buff+pos, sizeof(buff)-pos, "],\"p\":[");
  for(int i=0; i<24; i++) pos += snprintf(buff+pos, sizeof(buff)-pos, "%.1f%s", histP[i], i<23?",":"");
  
  pos += snprintf(buff+pos, sizeof(buff)-pos, "],\"r\":[");
  for(int i=0; i<24; i++) pos += snprintf(buff+pos, sizeof(buff)-pos, "%d%s", histR[i], i<23?",":"");
  
  snprintf(buff+pos, sizeof(buff)-pos, "]}");
  
  server.send(200, "application/json", buff);
}

void setup() {
  Serial.begin(115200);
  pinMode(LED_PIN, OUTPUT);
  Wire.begin(21, 22);
  bme.begin(0x76, &Wire);

  for(int i=0; i<24; i++) {
    histT[i] = -999.0; histH[i] = -999.0; histP[i] = -999.0; histR[i] = -999;
  }

  WiFiManager wm;
  
  // === ДОДАНО: СКИДАННЯ НАЛАШТУВАНЬ WI-FI ===
  wm.resetSettings(); 
  
  if (!wm.autoConnect("Meteo_Maksym_Setup")) {
    Serial.println("[-] Помилка підключення. Перезавантаження...");
    delay(3000);
    ESP.restart();
  }
  
  Serial.println("\n[+] WiFi OK! IP: " + WiFi.localIP().toString());

  // === ДОДАНО: Синхронізація часу (Україна) ===
  configTzTime("EET-2EEST,M3.5.0/3,M10.5.0/4", "pool.ntp.org", "time.nist.gov");
  
  // === ДОДАНО ДЛЯ FIREBASE (ПОЧАТОК) ===
  config.database_url = DATABASE_URL;
  config.signer.tokens.legacy_token = API_KEY; 

  Firebase.begin(&config, &auth);
  Firebase.reconnectWiFi(true);
  signupOK = true; 
  // === ДОДАНО ДЛЯ FIREBASE (КІНЕЦЬ) ===

  mqtt.setServer(mqtt_server, 1883);
  
  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.on("/history", handleHistory);
  server.begin();
}

void loop() {
  server.handleClient();
  if (!mqtt.connected()) {
    if (mqtt.connect("ESP32_Maksym_Final")) mqtt.publish(t_state, "Online");
  }
  mqtt.loop();

  unsigned long now = millis();

  if (now - prevMillis > 5000) {
    prevMillis = now;
    
    float t = bme.readTemperature();
    float h = bme.readHumidity();
    float p = bme.readPressure() / 133.32F;
    int r = getRain();

    if (!isnan(t) && !isnan(h) && !isnan(p)) { 
      if (t < minT) minT = t; if (t > maxT) maxT = t; sumT += t;
      if (h < minH) minH = h; if (h > maxH) maxH = h; sumH += h;
      if (p < minP) minP = p; if (p > maxP) maxP = p; sumP += p;
      if (r < minR) minR = r; if (r > maxR) maxR = r; sumR += r;
      countReads++; 
    }

    if (r > 1000) digitalWrite(LED_PIN, HIGH); else digitalWrite(LED_PIN, LOW);
    
    Serial.printf("Temp: %.1fC | Hum: %.1f%% | Pres: %.1fmmHg | Rain: %d\n", t, h, p, r);

    char payload[150];
    snprintf(payload, sizeof(payload), "{\n  \"temp\": %.1f,\n  \"hum\": %.1f,\n  \"pres\": %.1f,\n  \"rain\": %d\n}", t, h, p, r);
    mqtt.publish(t_telemetry, payload);

    // === ДОДАНО: Відправка в Current кожні 5 секунд з часом ===
    if (Firebase.ready() && signupOK) {
      FirebaseJson json;
      json.set("temp", t);
      json.set("hum", h);
      json.set("pres", p);
      json.set("rain", r);
      json.set("time", getTimeString()); // Додає поле time
      
      if (Firebase.RTDB.setJSON(&fbdo, "/MeteoStation/Current", &json)) {
        Serial.println("[+] Firebase: Поточні дані оновлено");
      }
    }
  }

  if (now - prevHistMillis > 60000) { 
    prevHistMillis = now;
    
    for(int i = 0; i < 23; i++) {
      histT[i] = histT[i+1]; histH[i] = histH[i+1];
      histP[i] = histP[i+1]; histR[i] = histR[i+1];
    }
    histT[23] = bme.readTemperature(); histH[23] = bme.readHumidity();
    histP[23] = bme.readPressure() / 133.32F; histR[23] = getRain();

    // === ДОДАНО ДЛЯ FIREBASE (ІСТОРІЯ З ЧАСОМ) ===
    if (Firebase.ready() && signupOK) {
      FirebaseJson json;
      json.set("temp", histT[23]);
      json.set("hum", histH[23]);
      json.set("pres", histP[23]);
      json.set("rain", histR[23]);
      json.set("time", getTimeString());
      
      // Створюємо папку з назвою часу (наприклад, 18:09:05)
      String path = "/MeteoStation/History/" + getTimeString();
      
      if (Firebase.RTDB.setJSON(&fbdo, path.c_str(), &json)) {
        Serial.println("[+] Firebase: Дані додано до історії");
      } else {
        Serial.println("[-] Firebase Error (History): " + fbdo.errorReason());
      }
    }
    // === ДОДАНО ДЛЯ FIREBASE (КІНЕЦЬ) ===
  }
}
