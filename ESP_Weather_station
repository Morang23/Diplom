    function draw(id, data, labels, color, unit, pts, type) {
      const cvs = document.getElementById(id);
      cvs.width = cvs.offsetWidth; cvs.height = cvs.offsetHeight;
      const ctx = cvs.getContext('2d'), w = cvs.width, h = cvs.height;
      ctx.clearRect(0,0,w,h);
      
      let validData = [];
      let validLabels = [];
      data.forEach((v, i) => {
          if (v > -500) {
              validData.push(v);
              if (labels && labels[i]) validLabels.push(labels[i]);
          }
      });

      if (validData.length < 2) return;

      let min = Math.min(...validData), max = Math.max(...validData);
      if (min === max) { min -= 1; max += 1; }
      const pad = (max - min) * 0.2; min -= pad; max += pad;
      
      const stepX = w / (pts - 1);
      const getY = (v) => h - 20 - ((v - min) / (max - min)) * (h - 30);

      ctx.beginPath();
      validData.forEach((v, i) => { if(i==0) ctx.moveTo(i*stepX, getY(v)); else ctx.lineTo(i*stepX, getY(v)); });
      ctx.strokeStyle = color; ctx.lineWidth = 3; ctx.lineCap = 'round'; ctx.lineJoin = 'round'; ctx.stroke();
      
      let gradient = ctx.createLinearGradient(0, 0, 0, h);
      gradient.addColorStop(0, color + '40'); 
      gradient.addColorStop(1, color + '00'); 
      ctx.lineTo((validData.length-1)*stepX, h); ctx.lineTo(0, h);
      ctx.fillStyle = gradient; ctx.fill();

      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const dotColor = isDark ? '#1c1c1e' : '#ffffff';

      validData.forEach((v, i) => {
        const x = i * stepX, y = getY(v);
        ctx.fillStyle = dotColor; ctx.beginPath(); ctx.arc(x, y, 4, 0, 7); ctx.fill();
        ctx.strokeStyle = color; ctx.lineWidth = 2; ctx.stroke();
      });

      cvs.onmousemove = (e) => {
        const rect = cvs.getBoundingClientRect();
        const mouseX = e.clientX - rect.left, mouseY = e.clientY - rect.top;
        let found = false;
        
        validData.forEach((v, i) => {
          const pointX = i * stepX, pointY = getY(v);
          
          if(Math.sqrt(Math.pow(mouseX - pointX, 2) + Math.pow(mouseY - pointY, 2)) < 15) {
            tt.style.display = 'block'; 
            tt.style.left = e.pageX + 15 + 'px'; 
            tt.style.top = e.pageY - 40 + 'px';
            
            let timeLabel = "";
            if (labels && validLabels[i]) {
              timeLabel = validLabels[i]; 
            } else {
              let pastTime = new Date();
              let diff = validData.length - 1 - i;
              pastTime.setMinutes(pastTime.getMinutes() - diff);
              timeLabel = pastTime.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            }

            let desc = "";
            if (type === 't') {
              if (v < 5) desc = "Холодно"; else if (v < 18) desc = "Прохолодно"; else if (v < 27) desc = "Комфортно"; else desc = "Спекотно";
            } else if (type === 'h') {
              if (v < 35) desc = "Сухо"; else if (v < 65) desc = "Норма"; else desc = "Волого";
            } else if (type === 'r') {
              if (v < 100) desc = "Без опадів"; else if (v < 1500) desc = "Мряка"; else desc = "Дощ";
            }
            // Для 'p' (тиск) змінна desc залишається порожньою

            let labelColor = isDark ? '#98989d' : '#86868b';
            let descHtml = desc !== "" ? ' • ' + desc : "";
            
            tt.innerHTML = '<div style="font-size:12px; color:'+labelColor+'; margin-bottom:4px; text-transform:uppercase; font-weight:600;">' + timeLabel + descHtml + '</div><div style="font-size:18px; font-weight:700;">' + v.toFixed(1) + ' <span style="font-size:14px;font-weight:normal">' + unit + '</span></div>';
            found = true;
          }
        });
        if(!found) tt.style.display = 'none';
      };
      cvs.onmouseleave = () => { tt.style.display = 'none'; };
    }

    function updateStatus(id, val, type) {
