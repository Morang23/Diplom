        else if (val < 27) { txt = "КОМФОРТНО"; baseCol = "#34c759"; }
        else { txt = "СПЕКА"; baseCol = "#ff3b30"; }
      } 
      else if (type === 'h') {
        if (val < 35) { txt = "СУХО"; baseCol = "#ff9500"; }
        else if (val < 65) { txt = "НОРМАЛЬНО"; baseCol = "#34c759"; }
        else { txt = "ВОЛОГО"; baseCol = "#007aff"; }
      }
      else if (type === 'r') {
        if (val < 100) { txt = "СУХО"; baseCol = "#8e8e93"; }
        else if (val < 1500) { txt = "МРЯКА"; baseCol = "#5ac8fa"; }
        else { txt = "ДОЩ"; baseCol = "#007aff"; }
      }
      
      el.innerText = txt;
      el.style.color = baseCol;
      
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      el.style.backgroundColor = isDark ? baseCol + "25" : baseCol + "15"; 
