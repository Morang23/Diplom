        }
        liveData.t.push(d.t); liveData.h.push(d.h); liveData.p.push(d.p); liveData.r.push(d.r); liveData.labels.push(now);

        draw('c_t', liveData.t, liveData.labels, '#ff3b30', '°C', maxPoints, 't'); 
        draw('c_h', liveData.h, liveData.labels, '#007aff', '%', maxPoints, 'h');  
        draw('c_p', liveData.p, liveData.labels, '#af52de', ' mmHg', maxPoints, 'p'); 
        draw('c_r', liveData.r, liveData.labels, '#5ac8fa', '', maxPoints, 'r');   
