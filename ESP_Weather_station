String getTimeString() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) {
    return "Time_Syncing"; // Поки час не синхронізувався
  }
  char timeStringBuff[30];
  // Формат Година:Хвилина:Секунда (наприклад 18:09:05)
  // Якщо захочете додати дату, змініть на "%Y-%m-%d %H:%M:%S"
  strftime(timeStringBuff, sizeof(timeStringBuff), "%H:%M:%S", &timeinfo);
  return String(timeStringBuff);
}

